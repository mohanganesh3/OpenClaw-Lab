#!/usr/bin/env node
/**
 * research_daemon.mjs — Long-Horizon Autonomous Research Daemon
 *
 * Runs 24/7 on your Mac. Processes a queue of research topics one by one.
 * Sends Telegram updates at every milestone.
 * Never stops unless you kill it.
 *
 * Usage:
 *   node src/research_daemon.mjs                          # Start with default topics
 *   node src/research_daemon.mjs --topic "my topic"       # Run one topic, then continue queue
 *   node src/research_daemon.mjs --queue queue.json       # Load topics from JSON file
 *   node src/research_daemon.mjs --status                 # Show current run status
 *
 * Queue file format (queue.json):
 *   ["topic 1", "topic 2", "topic 3"]
 *
 * The daemon:
 *   1. Picks next topic from queue
 *   2. Runs full 18-stage research pipeline
 *   3. Sends Telegram update at EVERY stage
 *   4. Sends final paper summary to Telegram
 *   5. Moves to next topic
 *   6. When queue empty: waits 30min, then re-runs queue with new seeds
 */

import { spawnSync, spawn } from "node:child_process";
import {
  existsSync, readFileSync, writeFileSync,
  mkdirSync, readdirSync, statSync
} from "node:fs";
import { join, dirname } from "node:path";
import { fileURLToPath } from "node:url";
import { homedir } from "node:os";
import { startBot } from "./telegram_bot.mjs";

const __dir = dirname(fileURLToPath(import.meta.url));
const ROOT = join(__dir, "..");

// ─── Telegram ────────────────────────────────────────────────────────────────

const SECRETS = join(homedir(), ".openclaw", "secrets");
const BOT_TOKEN = readSecret("telegram-bot-token.txt");
const CHAT_ID   = readSecret("telegram-chat-id.txt");

function readSecret(name) {
  const p = join(SECRETS, name);
  return existsSync(p) ? readFileSync(p, "utf8").trim() : null;
}

async function tg(text, silent = false) {
  if (!BOT_TOKEN || !CHAT_ID) { console.log("[TG disabled]", text.slice(0, 80)); return; }
  const chunks = [];
  for (let i = 0; i < text.length; i += 4000) chunks.push(text.slice(i, i + 4000));
  for (const chunk of chunks) {
    try {
      await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          chat_id: CHAT_ID,
          text: chunk,
          parse_mode: "HTML",
          disable_notification: silent,
        }),
      });
    } catch (e) {
      console.error("[TG] send error:", e.message);
    }
    if (chunks.length > 1) await sleep(500);
  }
}

function escHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

// ─── Daemon state ─────────────────────────────────────────────────────────────

const DAEMON_STATE_FILE = join(ROOT, "daemon_state.json");
const BOT_FLAGS_FILE    = join(ROOT, "bot_flags.json");

const DEFAULT_QUEUE = [
  "efficient long-context transformers",
  "test-time compute scaling for language models",
  "mixture of experts routing strategies",
  "multimodal foundation models visual grounding",
  "reinforcement learning from human feedback alignment",
  "neural architecture search automated machine learning",
  "continual learning catastrophic forgetting prevention",
  "retrieval augmented generation knowledge grounding",
];

function loadState() {
  if (existsSync(DAEMON_STATE_FILE)) {
    try { return JSON.parse(readFileSync(DAEMON_STATE_FILE, "utf8")); } catch {}
  }
  return {
    queue: [...DEFAULT_QUEUE],
    completed: [],
    loop: 0,
    started_at: Date.now(),
    last_topic: null,
    last_run_id: null,
    current_stage: null,
    current_start: null,
    total_papers: 0,
    total_experiments: 0,
  };
}

function saveState(state) {
  writeFileSync(DAEMON_STATE_FILE, JSON.stringify(state, null, 2));
}

// ─── Bot flag helpers (pause / skip / stop from Telegram) ─────────────────────

function readFlags() {
  try { return JSON.parse(readFileSync(BOT_FLAGS_FILE, "utf8")); } catch { return {}; }
}

function clearFlag(name) {
  const f = readFlags();
  delete f[name];
  writeFileSync(BOT_FLAGS_FILE, JSON.stringify(f, null, 2));
}

/**
 * Call between stages. If pause flag is set, wait until resume.
 * If stop flag is set, exit the process.
 * Returns true if we should SKIP the current topic.
 */
async function checkFlags(stageName, state) {
  const flags = readFlags();

  // STOP → exit daemon
  if (flags.stop) {
    console.log("\n[Daemon] 🛑 STOP flag set — halting daemon.");
    await tg("🛑 <b>Daemon stopped by Telegram command.</b>\nSend /resume to restart.");
    process.exit(0);
  }

  // SKIP → return true so caller skips to next topic
  if (flags.skip) {
    console.log(`\n[Daemon] ⏭ SKIP flag set — skipping topic: ${state.last_topic}`);
    clearFlag("skip");
    clearFlag("cancel_stage");
    return true; // skip
  }

  // PAUSE → block until resume
  if (flags.pause) {
    console.log(`\n[Daemon] ⏸ PAUSED at stage: ${stageName}`);
    await tg(`⏸ <b>Daemon paused at stage: ${escHtml(stageName)}</b>\nSend /resume to continue.`);
    while (true) {
      await sleep(3000);
      const f2 = readFlags();
      if (!f2.pause && !f2.stop) break;
      if (f2.stop) { await tg("🛑 <b>Daemon stopped.</b>"); process.exit(0); }
    }
    console.log("[Daemon] ▶️ Resumed!");
    await tg(`▶️ <b>Resumed from pause at stage: ${escHtml(stageName)}</b>`);
  }

  return false; // don't skip
}

// ─── Run pipeline stage and tail log ─────────────────────────────────────────

/**
 * Run a pipeline command and stream output.
 * Returns { success, runId, output }.
 */
async function runStage(cmd, args, { cwd = ROOT, timeoutMs = 3600000 } = {}) {
  return new Promise((resolve) => {
    console.log(`\n[Daemon] Running: ${cmd} ${args.join(" ")}`);
    const proc = spawn(cmd, args, {
      cwd,
      env: { ...process.env },
      stdio: ["ignore", "pipe", "pipe"],
    });

    let output = "";
    let runId = null;

    proc.stdout.on("data", (data) => {
      const text = data.toString();
      output += text;
      process.stdout.write(text);
      // Extract run_id if present
      const m = text.match(/"run_id"\s*:\s*"([^"]+)"/);
      if (m) runId = m[1];
    });

    proc.stderr.on("data", (data) => {
      const text = data.toString();
      output += text;
      process.stderr.write(text);
    });

    const timer = setTimeout(() => {
      console.error("\n[Daemon] Stage timeout — killing process");
      proc.kill("SIGTERM");
    }, timeoutMs);

    proc.on("close", (code) => {
      clearTimeout(timer);
      resolve({ success: code === 0, runId, output });
    });

    proc.on("error", (err) => {
      clearTimeout(timer);
      resolve({ success: false, runId: null, output: err.message });
    });
  });
}

/**
 * Get the most recent run directory.
 */
function getLatestRun() {
  const runsDir = join(ROOT, "runs");
  if (!existsSync(runsDir)) return null;
  const dirs = readdirSync(runsDir)
    .filter(d => d.startsWith("run_"))
    .map(d => ({ name: d, mtime: statSync(join(runsDir, d)).mtime }))
    .sort((a, b) => b.mtime - a.mtime);
  return dirs[0]?.name || null;
}

/**
 * Read run state JSON.
 */
function getRunState(runId) {
  const f = join(ROOT, "runs", runId, "run_state.json");
  if (!existsSync(f)) return null;
  try { return JSON.parse(readFileSync(f, "utf8")); } catch { return null; }
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
function fmt(ms) {
  const s = Math.floor(ms / 1000);
  if (s < 60) return `${s}s`;
  const m = Math.floor(s / 60);
  if (m < 60) return `${m}m ${s % 60}s`;
  return `${Math.floor(m / 60)}h ${m % 60}m`;
}

// ─── Full research loop for one topic ─────────────────────────────────────────
//
// Correct pipeline command sequence (matches openresearch.mjs dispatch):
//   start → discover → read → map → ideas → run-micro-probe → write → verify
//
// NOTE: "ideas" includes the adversarial reviewer council internally.
//       "run-micro-probe" runs the lightweight local ML experiments.
//       "verify" is the NeurIPS readiness check.

async function runOneTopic(topic, loopNum, queueRemaining) {
  const startTime = Date.now();

  await tg(
    `🔄 <b>Research Loop #${loopNum} Starting</b>\n` +
    `🔬 Topic: <b>${escHtml(topic)}</b>\n` +
    `📋 Topics in queue: <code>${queueRemaining}</code>\n` +
    `⏰ Started: ${new Date().toLocaleString("en-IN", { timeZone: "Asia/Kolkata" })}`
  );

  // ── STAGE 1: Create search plan ──
  console.log(`\n${"═".repeat(60)}`);
  console.log(`[Daemon] STAGE 1 - START: ${topic}`);
  await tg(`🗂 <b>Stage 1/7: Search Planning</b>\nGenerating 15 search queries for: <i>${escHtml(topic)}</i>`, true);

  const { success: startOk, runId: startRunId, output: startOut } = await runStage(
    "node", ["src/openresearch.mjs", "start", "--topic", topic],
    { timeoutMs: 300000 }
  );

  const activeRunId = startRunId || getLatestRun();
  if (!activeRunId || !startOk) {
    await tg(`❌ <b>Start Failed</b>\nCould not create search plan for: ${escHtml(topic)}`);
    return false;
  }

  const queriesMatch = startOut.match(/"queries"\s*:\s*(\d+)/);
  const numQueries = queriesMatch ? parseInt(queriesMatch[1]) : 0;
  await tg(`✅ <b>Search Plan Created</b>\n${numQueries} queries generated\nRun: <code>${activeRunId.slice(0,35)}</code>`, true);

  // ── STAGE 2: Discover papers via S2 ──
  console.log(`\n[Daemon] STAGE 2 - DISCOVER`);
  await tg(`🔍 <b>Stage 2/7: Literature Discovery</b>\nSearching Semantic Scholar with ${numQueries} queries...`);

  await runStage("node", ["src/openresearch.mjs", "discover", "--run", activeRunId], { timeoutMs: 300000 });

  const stateAfterDiscover = getRunState(activeRunId);
  const evCount = stateAfterDiscover?.evidence_count
    || stateAfterDiscover?.evidence_summaries?.length
    || 0;

  await tg(
    `🔍 <b>Discovery Complete</b>\n` +
    `📚 Papers found: <code>${evCount}</code>\n` +
    `⏱ ${fmt(Date.now() - startTime)}`
  );

  // ── STAGE 3: Read papers (full PDF for arXiv) ──
  console.log(`\n[Daemon] STAGE 3 - READ`);
  await tg(`📖 <b>Stage 3/7: Deep Reading</b>\nFetching full text for ${evCount} papers...`, true);

  await runStage("node", ["src/openresearch.mjs", "read", "--run", activeRunId], { timeoutMs: 900000 });

  const stateAfterRead = getRunState(activeRunId);
  const papersRead = stateAfterRead?.parsed_papers?.length
    || stateAfterRead?.full_pdf_reads
    || evCount;

  await tg(
    `📖 <b>Reading Complete</b>\n` +
    `✅ ${papersRead} papers fully processed\n` +
    `⏱ Elapsed: ${fmt(Date.now() - startTime)}`
  );

  // ── STAGE 4: Gap analysis ──
  console.log(`\n[Daemon] STAGE 4 - MAP`);
  await tg(`🔬 <b>Stage 4/7: Gap Analysis</b>\nAnalyzing research gaps across ${papersRead} papers...`, true);

  await runStage("node", ["src/openresearch.mjs", "map", "--run", activeRunId], { timeoutMs: 300000 });

  const stateAfterMap = getRunState(activeRunId);
  const gaps = stateAfterMap?.research_gaps || [];

  if (gaps.length > 0) {
    let gapMsg = `🔬 <b>Research Gaps Found: ${gaps.length}</b>\n\n`;
    gaps.slice(0, 5).forEach((g, i) => {
      gapMsg += `${i + 1}. <b>${escHtml((g.gap_title || g.text || "").slice(0, 80))}</b>\n`;
      if (g.testable_hypothesis) gapMsg += `   <i>${escHtml(g.testable_hypothesis.slice(0, 90))}</i>\n`;
    });
    gapMsg += `\n⏱ ${fmt(Date.now() - startTime)}`;
    await tg(gapMsg);
  } else {
    await tg(`🔬 <b>Gap Analysis Complete</b>\n(Gaps stored in run state)\n⏱ ${fmt(Date.now() - startTime)}`, true);
  }

  // ── STAGE 5: Idea generation + adversarial reviewer council ──
  console.log(`\n[Daemon] STAGE 5 - IDEAS + REVIEW`);
  await tg(`💡 <b>Stage 5/7: Ideas + Adversarial Review</b>\nGenerating ideas → 4 reviewers × 2 phases...`);

  await runStage("node", ["src/openresearch.mjs", "ideas", "--run", activeRunId], { timeoutMs: 1200000 });

  const stateAfterIdeas = getRunState(activeRunId);
  const ideas = stateAfterIdeas?.idea_tree || stateAfterIdeas?.ideas || [];
  const candidates = stateAfterIdeas?.experiment_candidates || [];

  let ideaMsg = `💡 <b>${ideas.length} Ideas Generated</b>\n`;
  ideaMsg += `✅ Experiment candidates: <code>${candidates.length}</code>\n\n`;
  ideas.slice(0, 4).forEach((idea, i) => {
    const score = idea.reviewer_average || idea.novelty_score || "?";
    ideaMsg += `${i + 1}. <b>${escHtml((idea.title || "").slice(0, 65))}</b>\n`;
    ideaMsg += `   Score: <code>${score}</code> | Gap: <code>${idea.source_gap_id || "?"}</code>\n`;
  });
  ideaMsg += `\n⏱ ${fmt(Date.now() - startTime)}`;
  await tg(ideaMsg);

  // ── STAGE 6: Run micro-probe experiments ──
  console.log(`\n[Daemon] STAGE 6 - RUN-MICRO-PROBE`);
  await tg(`🧪 <b>Stage 6/7: Micro-Probe Experiments</b>\nRunning lightweight ML experiments on Mac M4...`);

  const { output: probeOut } = await runStage(
    "node", ["src/openresearch.mjs", "run-micro-probe", "--run", activeRunId],
    { timeoutMs: 1800000 }
  );

  const stateAfterProbe = getRunState(activeRunId);
  const experiments = stateAfterProbe?.experiment_results || [];
  const successful = experiments.filter(e => e.success || e.status === "passed").length;

  if (experiments.length > 0) {
    let expMsg = `🧪 <b>Experiments Complete</b>\n`;
    expMsg += `✅ Successful: <code>${successful}/${experiments.length}</code>\n\n`;
    experiments.slice(0, 3).forEach(e => {
      const m = e.metrics || e.results || {};
      expMsg += `• <b>${escHtml((e.idea_title || e.experiment_id || "exp").slice(0, 50))}</b>\n`;
      const acc = m.accuracy_mean ?? m.accuracy ?? m.f1_mean ?? m.score;
      if (acc != null) expMsg += `  Score: <code>${typeof acc === "number" ? (acc > 1 ? acc.toFixed(2) : (acc * 100).toFixed(1) + "%") : acc}</code>`;
      expMsg += "\n";
    });
    expMsg += `\n⏱ ${fmt(Date.now() - startTime)}`;
    await tg(expMsg);
  } else {
    await tg(`🧪 <b>Experiments done</b> (results in run state)\n⏱ ${fmt(Date.now() - startTime)}`, true);
  }

  // ── STAGE 7: Write paper ──
  console.log(`\n[Daemon] STAGE 7 - WRITE`);
  await tg(`📄 <b>Stage 7/7: Writing Paper</b>\nDrafting full research paper...`, true);

  await runStage("node", ["src/openresearch.mjs", "write", "--run", activeRunId], { timeoutMs: 600000 });

  // ── Verify (NeurIPS readiness check) ──
  console.log(`\n[Daemon] VERIFY - NeurIPS checklist`);
  await runStage("node", ["src/openresearch.mjs", "verify", "--run", activeRunId], { timeoutMs: 120000 });

  // ── FINAL SUMMARY ──
  const finalState = getRunState(activeRunId);
  const paperPath = finalState?.final_output_path
    || `runs/${activeRunId}/paper_draft.md`;
  const verifyResult = finalState?.verify_result || finalState?.neurips_readiness;
  const verdict = verifyResult?.verdict || "complete";

  const elapsed = Date.now() - startTime;

  await tg(
    `🎉 <b>Research Complete!</b>\n\n` +
    `🔬 Topic: <b>${escHtml(topic)}</b>\n` +
    `📚 Papers read: <code>${papersRead}</code>\n` +
    `🔎 Gaps found: <code>${gaps.length}</code>\n` +
    `💡 Ideas generated: <code>${ideas.length}</code>\n` +
    `🧬 Candidates: <code>${candidates.length}</code>\n` +
    `🧪 Experiments: <code>${experiments.length}</code> (${successful} passed)\n` +
    `📝 Verdict: <i>${escHtml(verdict)}</i>\n\n` +
    `📄 Paper: <code>${paperPath.split("/").slice(-2).join("/")}</code>\n` +
    `⏱ Total: <b>${fmt(elapsed)}</b>\n` +
    `🔑 Run: <code>${activeRunId?.slice(0, 35)}</code>`
  );

  return true;
}

// ─── Main daemon loop ─────────────────────────────────────────────────────────

async function main() {
  const args = process.argv.slice(2);

  // --status: print current state and exit
  if (args.includes("--status")) {
    const state = loadState();
    console.log(JSON.stringify(state, null, 2));
    process.exit(0);
  }

  // --topic: prepend a topic to the queue
  const topicIdx = args.indexOf("--topic");
  const extraTopics = [];
  if (topicIdx >= 0 && args[topicIdx + 1]) {
    extraTopics.push(args[topicIdx + 1]);
  }

  // --queue: load topics from file
  const queueIdx = args.indexOf("--queue");
  if (queueIdx >= 0 && args[queueIdx + 1] && existsSync(args[queueIdx + 1])) {
    try {
      const loaded = JSON.parse(readFileSync(args[queueIdx + 1], "utf8"));
      if (Array.isArray(loaded)) extraTopics.push(...loaded);
    } catch {}
  }

  const state = loadState();
  if (extraTopics.length > 0) {
    state.queue = [...extraTopics, ...state.queue];
    saveState(state);
  }

  // Announce start
  await tg(
    `🚀 <b>OpenResearchOS Daemon Started</b>\n\n` +
    `📋 Queue: <code>${state.queue.length}</code> topics\n` +
    `🔄 Loop: <code>#${state.loop + 1}</code>\n` +
    `💻 Running on your Mac (MacBook Air M4)\n\n` +
    `Topics queued:\n` +
    state.queue.slice(0, 5).map((t, i) => `  ${i + 1}. ${escHtml(t)}`).join("\n") +
    (state.queue.length > 5 ? `\n  ... and ${state.queue.length - 5} more` : "")
  );

  let iterations = 0;
  const MAX_ITERATIONS = 1000; // Safety: never truly infinite

  while (iterations < MAX_ITERATIONS) {
    iterations++;

    if (state.queue.length === 0) {
      // Queue empty — refill and wait
      console.log("\n[Daemon] Queue empty. Waiting 30 minutes then restarting with fresh queue...");
      await tg(
        `😴 <b>Queue Empty</b>\n` +
        `Completed <code>${state.completed.length}</code> research topics this session.\n` +
        `Waiting 30 minutes before starting next cycle...\n\n` +
        `To add topics: edit <code>daemon_state.json</code> queue array.`
      );

      await sleep(30 * 60 * 1000);

      // Refill queue from defaults (rotating)
      state.loop++;
      state.queue = DEFAULT_QUEUE.map(t => `${t} (cycle ${state.loop})`);
      saveState(state);

      await tg(
        `🔄 <b>New Research Cycle #${state.loop}</b>\n` +
        `Starting fresh with ${state.queue.length} topics.`
      );
      continue;
    }

    const topic = state.queue.shift();
    state.last_topic = topic;
    saveState(state);

    console.log(`\n${"═".repeat(60)}`);
    console.log(`[Daemon] Starting topic ${iterations}: "${topic}"`);
    console.log(`[Daemon] Queue remaining: ${state.queue.length}`);

    try {
      const success = await runOneTopic(topic, state.loop + 1, state.queue.length);
      if (success) {
        state.completed.push({ topic, timestamp: Date.now() });
      }
    } catch (err) {
      console.error(`\n[Daemon] ERROR for topic "${topic}":`, err.message);
      await tg(
        `❌ <b>Pipeline Error</b>\n` +
        `Topic: <i>${escHtml(topic)}</i>\n` +
        `Error: <code>${escHtml(err.message?.slice(0, 200))}</code>\n` +
        `Continuing to next topic...`
      );
    }

    saveState(state);

    // Brief pause between topics
    if (state.queue.length > 0) {
      console.log(`\n[Daemon] Topic complete. Pausing 2 minutes before next topic...`);
      await sleep(2 * 60 * 1000);
    }
  }

  await tg(`✅ <b>Daemon completed</b> ${iterations} research cycles.`);
}

// ─── Handle signals gracefully ────────────────────────────────────────────────

process.on("SIGINT", async () => {
  console.log("\n[Daemon] Received SIGINT — shutting down gracefully...");
  await tg("⏹ <b>OpenResearchOS Daemon stopped</b> (SIGINT)").catch(() => {});
  process.exit(0);
});

process.on("SIGTERM", async () => {
  console.log("\n[Daemon] Received SIGTERM — shutting down gracefully...");
  await tg("⏹ <b>OpenResearchOS Daemon stopped</b> (SIGTERM)").catch(() => {});
  process.exit(0);
});

process.on("uncaughtException", async (err) => {
  console.error("[Daemon] Uncaught exception:", err);
  await tg(`🔥 <b>Daemon crash (restarting)</b>\n<code>${escHtml(err.message?.slice(0, 200))}</code>`).catch(() => {});
  // Don't exit — let daemon continue if possible
});

// Run
main().catch(async (err) => {
  console.error("[Daemon] Fatal:", err);
  await tg(`💀 <b>Daemon fatal error:</b>\n<code>${escHtml(err.message)}</code>`).catch(() => {});
  process.exit(1);
});
